# RemoteDev environment variables
# Copy to .env.local and fill in values.

# Required: 32-byte hex secret shared between bridge and Next.js server
BRIDGE_AUTH_TOKEN=

# Required: 32-byte hex client secret (stored in Keychain on Mac)
# Generate: openssl rand -hex 32
REMOTEDEV_CLIENT_SECRET=

# Tailscale hostname (e.g. mac.tailnet-name.ts.net)
TAILNET_HOST=localhost

# Colon-separated list of allowed working directories
# Defaults to $HOME
ALLOWED_ROOTS=

# TLS certificate paths (from tailscale cert)
TLS_CERT=/var/lib/tailscale/certs/${TAILNET_HOST}.crt
TLS_KEY=/var/lib/tailscale/certs/${TAILNET_HOST}.key

# Ports (7000/7001 avoid conflicts with common local dev servers like React/Next.js)
BRIDGE_PORT=7001
UI_PORT=7000

# Minimum required claude version (optional)
CLAUDE_MIN_VERSION=

# Log level (trace|debug|info|warn|error|fatal)
LOG_LEVEL=info

# ──────────────────────────────────────────────────────────────────────────
# Next.js public vars (accessible in browser)

NEXT_PUBLIC_BRIDGE_WS_URL=wss://localhost:7001
NEXT_PUBLIC_CLIENT_SECRET=
NEXT_PUBLIC_WORKING_DIR=
