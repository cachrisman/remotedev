#!/usr/bin/env bash
# bin/setup — Phase 0: TLS + Tailscale + Client Secret setup guide.
#
# Interactive setup for initial RemoteDev configuration.
# Run once to generate secrets and configure the environment.
set -euo pipefail

cd "$(dirname "$0")/.."

green() { echo -e "\033[32m$*\033[0m"; }
yellow(){ echo -e "\033[33m$*\033[0m"; }
bold()  { echo -e "\033[1m$*\033[0m"; }

bold "RemoteDev Setup (Phase 0)"
echo ""

# ──────────────────────────────────────────────────────────────────────────
# Step 1: Tailscale
bold "Step 1: Tailscale"
if command -v tailscale &>/dev/null; then
  TAILNET_HOST=$(tailscale status --json 2>/dev/null | jq -r '.Self.DNSName | rtrimstr(".")' 2>/dev/null || echo "")
  if [ -n "$TAILNET_HOST" ]; then
    green "  ✓ Tailscale active: $TAILNET_HOST"
  else
    yellow "  ⚠ Tailscale is installed but may not be connected"
    TAILNET_HOST="${TAILNET_HOST:-mac.your-tailnet.ts.net}"
  fi
else
  yellow "  ⚠ Tailscale not found. Install from https://tailscale.com"
  TAILNET_HOST="mac.your-tailnet.ts.net"
fi

echo ""
read -rp "  Enter your tailnet hostname [$TAILNET_HOST]: " INPUT_HOST
TAILNET_HOST="${INPUT_HOST:-$TAILNET_HOST}"

# ──────────────────────────────────────────────────────────────────────────
# Step 2: TLS cert
bold ""
bold "Step 2: TLS Certificate"
CERT_PATH="/var/lib/tailscale/certs/${TAILNET_HOST}.crt"
KEY_PATH="/var/lib/tailscale/certs/${TAILNET_HOST}.key"

if [ -f "$CERT_PATH" ]; then
  green "  ✓ Certificate found at $CERT_PATH"
else
  echo "  Run: tailscale cert $TAILNET_HOST"
  echo "  Cert will be saved to: $CERT_PATH"
fi

# ──────────────────────────────────────────────────────────────────────────
# Step 3: tailscale serve (HTTPS reverse proxy for the UI on port 7000)
bold ""
bold "Step 3: Tailscale HTTPS proxy"
if command -v tailscale &>/dev/null; then
  # Configure tailscale serve to proxy external HTTPS:7000 → local HTTP:17000.
  # This is idempotent — safe to re-run.
  if tailscale serve --bg --https=7000 http://localhost:17000 2>/dev/null; then
    green "  ✓ tailscale serve configured: https://${TAILNET_HOST}:7000 → http://localhost:17000"
  else
    yellow "  ⚠ Could not configure tailscale serve automatically."
    yellow "    Run manually: tailscale serve --bg --https=7000 http://localhost:17000"
  fi
else
  yellow "  ⚠ Tailscale not found — skipping. Run manually once Tailscale is installed:"
  yellow "    tailscale serve --bg --https=7000 http://localhost:17000"
fi

# ──────────────────────────────────────────────────────────────────────────
# Step 4: Secrets
bold ""
bold "Step 4: Generate Secrets"

BRIDGE_TOKEN=$(openssl rand -hex 32)
CLIENT_SECRET=$(openssl rand -hex 32)

green "  Generated BRIDGE_AUTH_TOKEN"
green "  Generated REMOTEDEV_CLIENT_SECRET"

# Store client secret in macOS Keychain if available
if command -v security &>/dev/null; then
  security delete-generic-password -a remotedev -s remotedev-client-secret 2>/dev/null || true
  security add-generic-password -a remotedev -s remotedev-client-secret -w "$CLIENT_SECRET"
  green "  ✓ Client secret stored in macOS Keychain"
fi

# ──────────────────────────────────────────────────────────────────────────
# Step 5: ALLOWED_ROOTS
bold ""
bold "Step 5: Working Directory"
DEFAULT_ROOT="${HOME}"
read -rp "  Enter allowed root directory [$DEFAULT_ROOT]: " INPUT_ROOT
ALLOWED_ROOT="${INPUT_ROOT:-$DEFAULT_ROOT}"

# ──────────────────────────────────────────────────────────────────────────
# Step 6: Write .env.local
bold ""
bold "Step 6: Writing configuration"

cat > ecosystem.config.local.js << EOF
// Auto-generated by bin/setup — customize as needed
process.env.TAILNET_HOST = '${TAILNET_HOST}';
process.env.BRIDGE_AUTH_TOKEN = '${BRIDGE_TOKEN}';
process.env.REMOTEDEV_CLIENT_SECRET = '${CLIENT_SECRET}';
process.env.ALLOWED_ROOTS = '${ALLOWED_ROOT}';
process.env.TLS_CERT = '${CERT_PATH}';
process.env.TLS_KEY = '${KEY_PATH}';
EOF

green "  ✓ Written to ecosystem.config.local.js"

# ──────────────────────────────────────────────────────────────────────────
# Summary
echo ""
bold "Setup complete!"
echo ""
echo "  Next steps:"
echo "  1. Store client secret in iPhone Safari password manager:"
yellow "     $CLIENT_SECRET"
echo ""
echo "  2. Build the UI:  cd ui && npm run build && cd .."
echo ""
echo "  3. Start the servers: pm2 start ecosystem.config.js && pm2 save"
echo "     (ecosystem.config.js loads ecosystem.config.local.js automatically)"
echo ""
echo "  4. Open iPhone Safari: https://${TAILNET_HOST}:7000"
echo ""
echo "  5. Run Phase 0 iOS smoke gate: ./bin/test-tailnet"
