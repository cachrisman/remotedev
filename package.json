{
  "name": "remotedev",
  "version": "0.16.0",
  "description": "Control your Mac dev environment from your iPhone via a mobile chat interface",
  "private": true,
  "workspaces": [
    "bridge-server",
    "ui"
  ],
  "scripts": {
    "dev": "./bin/dev",
    "stop": "pm2 stop all",
    "logs": "pm2 logs",
    "status": "pm2 status",
    "reload": "./bin/reload",
    "test": "node --test bridge-server/test/**/*.test.js",
    "test:tailnet": "./bin/test-tailnet"
  },
  "engines": {
    "node": ">=20 <25"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "pm2": "^6.0.14"
  }
}
